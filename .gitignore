# ───── Secrets / project-specific config ─────
# These contain Firebase API keys + project IDs. They're not "secret" per
# Google's definition (clients restrict them by package + Firestore rules)
# but committing them ties this code to one specific Firebase project and
# is a habit better avoided for a repo that may go public.
# Re-generate with:  flutterfire configure --project=<id> --platforms=android
mobile/lib/firebase_options.dart
mobile/android/app/google-services.json

# ───── Flutter / Dart ─────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.metadata
mobile/build/
mobile/pubspec.lock
mobile/.packages
mobile/coverage/

# Flutter Android / iOS native build outputs
mobile/android/.gradle/
mobile/android/captures/
mobile/android/local.properties
mobile/android/app/debug
mobile/android/app/profile
mobile/android/app/release
mobile/android/key.properties
mobile/android/**/*.keystore
mobile/android/**/*.jks
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec

# ───── Cloud Functions (Node) ─────
functions/node_modules/
functions/lib/
functions/.runtimeconfig.json
functions/*.log

# ───── Firebase CLI ─────
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
.emulator-data/

# ───── Editors / OS ─────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db

# ───── Misc ─────
*.log
*.tmp
