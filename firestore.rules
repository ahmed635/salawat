rules_version = '2';

// All counter writes go through the incrementCount Cloud Function (which uses
// the Admin SDK and bypasses these rules). Clients are limited to:
//   - reading their own profile + leaderboards + global counters
//   - writing to users/{uid} but only displayName / country / lbVisible
//
// Anything else is denied, so a malicious client can't write directly to
// global counters or fake leaderboard scores.

service cloud.firestore {
  match /databases/{db}/documents {

    // --- Global counters (sharded) - readable by anyone, writes server-only.
    match /globalShards/{shardId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Lifetime leaderboard - readable by anyone, writes server-only.
    match /leaderboardLifetime/{uid} {
      allow read: if true;
      allow write: if false;
    }

    // --- Daily leaderboard - readable by anyone, writes server-only.
    match /leaderboardDaily/{day} {
      allow read: if true;
      allow write: if false;

      match /users/{uid} {
        allow read: if true;
        allow write: if false;
      }
    }

    // --- User profile - the user can create/edit a small whitelisted subset.
    // The client may only touch displayName / country / lbVisible.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys()
                         .hasOnly(['displayName', 'country', 'lbVisible']);

      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['displayName', 'country', 'lbVisible']);

      allow delete: if false;
    }

    // --- Idempotency / audit / anything else - server-only.
    match /idempotency/{any} { allow read, write: if false; }
    match /{document=**}     { allow read, write: if false; }
  }
}
